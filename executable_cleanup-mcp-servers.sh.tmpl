#!/bin/sh
# Cleanup MCP servers - removes all MCP servers from user and project scope
#
# NOTE: MCP servers are now managed project-by-project.
# This script is primarily for cleanup of old user-scoped installations.
#
# WARNING: This script will disrupt active Claude sessions!
# Only run this when:
# - You need to clean up old user-scoped MCP servers
# - You need to fix broken MCP configurations
# - No Claude Code sessions are running
#
# After cleanup, use /configure:mcp command to reinstall servers per-project.
# Configuration is read from .chezmoidata.toml [mcp_servers] section.

set -e

echo "⚠️  WARNING: This will disconnect all active MCP servers!"
echo "Make sure no Claude Code sessions are running."
echo ""
printf "Continue? (y/N) "
read -r reply
if [ "$reply" != "y" ] && [ "$reply" != "Y" ]; then
    echo "Cleanup cancelled."
    exit 0
fi

echo "🧹 Cleaning up MCP servers..."

# Remove all enabled MCP servers
{{- range $name, $config := .mcp_servers }}
{{- if $config.enabled }}
echo "Removing {{ $name }}..."
claude mcp remove --scope={{ $config.scope }} {{ $name }} || true
{{- end }}
{{- end }}

echo ""
echo "✅ Cleanup complete. MCP servers are now managed per-project."
echo ""
echo "To reinstall servers into a project, use:"
echo "  /configure:mcp   (interactive, writes to the project's .mcp.json)"
