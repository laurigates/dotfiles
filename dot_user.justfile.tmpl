# Global justfile — recipes available from ANY directory via `just -g` / `just --global-justfile`.
#
# `just -g <recipe>` ignores the current directory's justfile and reads this
# file (~/.user.justfile) instead, so e.g.
#     just -g plugins-list
# works inside any repo (even one with its own justfile).
#
# Source of truth lives in the dotfiles repo at private_dot_config/just/plugins.just;
# chezmoi applies it to ~/.config/just/plugins.just, which this file imports.
# Edit recipes there, not here.

import '{{ .chezmoi.homeDir }}/.config/just/plugins.just'
