# Global justfile — recipes available from ANY directory via `just -g` / `just --global-justfile`.
#
# `just -g <recipe>` ignores the current directory's justfile and reads the
# GLOBAL justfile instead. just's global search path is (first match wins):
#     $XDG_CONFIG_HOME/just/justfile  →  ~/.config/just/justfile  →  ~/justfile  →  ~/.justfile
# so this file MUST live at ~/.config/just/justfile to be found. (~/.user.justfile
# is NOT on that path — an earlier version put it there and it never worked.)
#
# Source of truth for the recipes lives beside this file:
#   • plugins.just  — Claude plugin management (plugins-*)
#   • claude.just   — Claude Code setup (mcp-*, cclsp, claude-setup, settings-audit)
#   • git.just      — Git branch hygiene (branch-audit)
# Edit those, then `chezmoi apply`. Imports are relative to this file's directory.

# Claude model used by headless `claude -p` recipes (single source of truth,
# referenced as {{claude_model}} across the imported recipe files). Update here
# to bump the version everywhere.
claude_model := "claude-opus-4-8"

import 'plugins.just'
import 'claude.just'
import 'git.just'
